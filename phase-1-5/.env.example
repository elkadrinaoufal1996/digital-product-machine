# ─── Phase 1.5 — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# Never commit .env to a Git repository.
#
# Usage:
#   cp .env.example .env
#   python phase-1-5/agents/scraper.py

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Used by downstream skills (06→08). Reuse from phase-1/.env.
ANTHROPIC_KEY=your_key_here

# ─── Apify ────────────────────────────────────────────────────────────────────
# Token for TikTok hashtag scraper actor: clockworks/tiktok-hashtag-scraper
# Get at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_key_here

# ─── Firecrawl ────────────────────────────────────────────────────────────────
# API key for competitor page scraping (HTML + Markdown)
# Get at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_KEY=your_key_here

# ─── Tavily ───────────────────────────────────────────────────────────────────
# API key for Reddit/forum persona voice searches
# Get at: https://app.tavily.com/home
TAVILY_KEY=your_key_here

# ─── Configuration ────────────────────────────────────────────────────────────
# Target market (inherited from Phase 1 — only US supported)
MARKET=US
