# ─── Python ──────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# ─── Secrets ─────────────────────────────────────────────
.env
.env.local
*.key
*.pem

# ─── Outputs (real business artifacts — never push) ──────
phase-1/outputs/*.json
phase-1/outputs/*.md
phase-1-5/outputs/*.json
phase-1-5/outputs/*.md
phase-2/outputs/*.json
phase-2/outputs/*.md
phase-3/outputs/*.json
phase-3/outputs/*.md
!**/outputs/.gitkeep

# ─── Diagnostic files ────────────────────────────────────
**/outputs/*-DIAGNOSTIC-FAILED.txt

# ─── IDE / OS ────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
