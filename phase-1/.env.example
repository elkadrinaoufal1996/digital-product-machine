# ─── Phase 1 — Variables d'environnement ────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos clés réelles.
# Ne jamais committer .env dans un dépôt Git.
#
# Usage:
#   cp .env.example .env
#   python phase1.py --market=US

# ─── Anthropic API ───────────────────────────────────────────────────────────
# Clé API Anthropic (claude-sonnet-4-20250514)
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_KEY=your_key_here

# ─── Apify ───────────────────────────────────────────────────────────────────
# Token Apify pour les scrapers (Gumroad, Amazon, Etsy, TikTok, Instagram)
# Obtenir sur : https://console.apify.com/account/integrations
APIFY_TOKEN=your_key_here

# ─── Firecrawl ───────────────────────────────────────────────────────────────
# Clé API Firecrawl pour le scraping de pages web (concurrent pricing, VSL)
# Obtenir sur : https://www.firecrawl.dev/app/api-keys
FIRECRAWL_KEY=your_key_here

# ─── Tavily ──────────────────────────────────────────────────────────────────
# Clé API Tavily pour les recherches Reddit et web search
# Obtenir sur : https://app.tavily.com/home
TAVILY_KEY=your_key_here

# ─── Configuration ───────────────────────────────────────────────────────────
# Marché cible (seul US supporté en Phase 1)
MARKET=US
