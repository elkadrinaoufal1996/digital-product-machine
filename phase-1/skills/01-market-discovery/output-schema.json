{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill 01 Output — 01-market-discovery.json",
  "description": "15 US niches with raw demand signals and preliminary UVZs. Input for Skill 02.",
  "type": "object",
  "required": ["meta", "niches", "eliminated_log"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["skill", "market", "generated_at", "data_sources_status"],
      "properties": {
        "skill": { "type": "string", "const": "01-market-discovery" },
        "market": { "type": "string", "const": "US" },
        "generated_at": { "type": "string", "format": "date-time" },
        "data_sources_status": {
          "type": "object",
          "properties": {
            "gumroad": { "type": "string", "enum": ["OK", "PARTIAL", "FAILED"] },
            "kindle": { "type": "string", "enum": ["OK", "PARTIAL", "FAILED"] },
            "etsy": { "type": "string", "enum": ["OK", "PARTIAL", "FAILED"] },
            "tiktok": { "type": "string", "enum": ["OK", "PARTIAL", "FAILED"] },
            "instagram": { "type": "string", "enum": ["OK", "PARTIAL", "FAILED"] },
            "reddit": { "type": "string", "enum": ["OK", "PARTIAL"] }
          }
        }
      }
    },
    "niches": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["niche_id", "niche_name", "status", "signal_sources", "demand_signals", "preliminary_uvz"],
        "properties": {
          "niche_id": { "type": "string", "pattern": "^N(0[1-9]|1[0-5])$" },
          "niche_name": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "BORDERLINE"] },
          "signal_sources": {
            "type": "array",
            "items": { "type": "string", "enum": ["gumroad", "kindle", "etsy", "tiktok", "instagram", "reddit"] },
            "minItems": 2
          },
          "demand_signals": {
            "type": "object",
            "properties": {
              "gumroad": {
                "type": "object",
                "properties": {
                  "product_count": { "type": "integer" },
                  "avg_sales_comparable": { "type": "number" },
                  "price_range": { "type": "string" }
                }
              },
              "kindle": {
                "type": "object",
                "properties": {
                  "bsr_range": { "type": "string" },
                  "review_velocity": { "type": "string" },
                  "category": { "type": "string" }
                }
              },
              "reddit": {
                "type": "object",
                "properties": {
                  "pain_posts_count": { "type": "integer" },
                  "top_pain_verbatim": { "type": "string" },
                  "subreddit": { "type": "string" },
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "etsy": {
                "type": "object",
                "properties": {
                  "product_count": { "type": "integer" },
                  "avg_sales": { "type": "number" },
                  "price_range": { "type": "string" }
                }
              },
              "tiktok": {
                "type": "object",
                "properties": {
                  "hashtag": { "type": "string" },
                  "views_30d": { "type": "integer" },
                  "growth_rate_percent": { "type": "number" }
                }
              },
              "instagram": {
                "type": "object",
                "properties": {
                  "hashtag": { "type": "string" },
                  "post_count": { "type": "integer" },
                  "avg_engagement": { "type": "number" }
                }
              }
            }
          },
          "preliminary_uvz": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "items": {
              "type": "object",
              "required": ["uvz_label", "signal_anchor", "source_url"],
              "properties": {
                "uvz_label": { "type": "string" },
                "signal_anchor": { "type": "string" },
                "source_url": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "eliminated_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_name", "reason_code", "reason_detail"],
        "properties": {
          "cluster_name": { "type": "string" },
          "reason_code": { "type": "string", "enum": ["LEGAL", "SATURATED", "NO-PAY", "SEASONAL", "PLATFORM-RISK"] },
          "reason_detail": { "type": "string" }
        }
      }
    }
  }
}
