{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill 02 Output — 02-scored.json",
  "description": "Top 5 niches scored /100 + Top 3 ebook ideas per niche scored /100. Input for Skills 03, 04, 05.",
  "type": "object",
  "required": ["meta", "niche_shortlist", "full_scoring_log"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["skill", "input_file", "generated_at", "web_search_confirmed", "niches_scored", "niches_in_shortlist"],
      "properties": {
        "skill": { "type": "string", "const": "02-niche-idea-scorer" },
        "input_file": { "type": "string", "const": "01-market-discovery.json" },
        "generated_at": { "type": "string", "format": "date-time" },
        "web_search_confirmed": { "type": "boolean" },
        "niches_scored": { "type": "integer", "minimum": 10, "maximum": 15 },
        "niches_in_shortlist": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "niche_shortlist": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["niche_id", "niche_name", "matrix_a_score", "tier_demand", "verdict", "vc_challenges", "calculation_chain", "ebook_ideas"],
        "properties": {
          "niche_id": { "type": "string" },
          "niche_name": { "type": "string" },
          "matrix_a_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "tier_demand": { "type": "string", "enum": ["TIER_1", "TIER_2", "TIER_3"] },
          "verdict": { "type": "string", "enum": ["GO", "CONDITIONAL_GO", "NO_GO"] },
          "vc_challenges": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["criterion", "challenge"],
              "properties": {
                "criterion": { "type": "string" },
                "challenge": { "type": "string" }
              }
            }
          },
          "calculation_chain": { "type": "string", "description": "Full chain of thought calculation" },
          "ebook_ideas": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["idea_id", "working_title", "transformation_before", "transformation_after", "matrix_b_score", "quick_win_ch1", "verdict", "calculation_chain"],
              "properties": {
                "idea_id": { "type": "string", "pattern": "^N[0-9]+-I[1-3]$" },
                "working_title": { "type": "string" },
                "transformation_before": { "type": "string" },
                "transformation_after": { "type": "string" },
                "matrix_b_score": { "type": "number", "minimum": 0, "maximum": 100 },
                "quick_win_ch1": { "type": "string", "description": "Precise description of result achievable in <20 min" },
                "verdict": { "type": "string", "enum": ["GO", "RISKY", "NO_GO"] },
                "calculation_chain": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "full_scoring_log": {
      "type": "array",
      "description": "All 15 niches scored, including those not in shortlist",
      "items": {
        "type": "object",
        "required": ["niche_id", "niche_name", "matrix_a_score", "included_in_shortlist"],
        "properties": {
          "niche_id": { "type": "string" },
          "niche_name": { "type": "string" },
          "matrix_a_score": { "type": "number" },
          "included_in_shortlist": { "type": "boolean" },
          "exclusion_reason": { "type": "string" }
        }
      }
    }
  }
}
