{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill 02 Input",
  "description": "Expects 01-market-discovery.json. Web search must be available.",
  "type": "object",
  "required": ["meta", "niches"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["skill", "market", "generated_at"],
      "properties": {
        "skill": { "type": "string", "const": "01-market-discovery" },
        "market": { "type": "string" },
        "generated_at": { "type": "string" },
        "data_sources_status": { "type": "object" }
      }
    },
    "niches": {
      "type": "array",
      "minItems": 10,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": ["niche_id", "niche_name", "status", "signal_sources", "demand_signals", "preliminary_uvz"],
        "properties": {
          "niche_id": { "type": "string" },
          "niche_name": { "type": "string" },
          "status": { "type": "string", "enum": ["ACTIVE", "BORDERLINE"] },
          "signal_sources": { "type": "array", "minItems": 2 },
          "demand_signals": { "type": "object" },
          "preliminary_uvz": { "type": "array", "minItems": 1 }
        }
      }
    },
    "eliminated_log": { "type": "array" }
  }
}
