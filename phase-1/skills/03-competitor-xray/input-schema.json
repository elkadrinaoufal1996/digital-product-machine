{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill 03 Input",
  "description": "Expects 02-scored.json with a populated niche_shortlist.",
  "type": "object",
  "required": ["meta", "niche_shortlist"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["skill", "web_search_confirmed"],
      "properties": {
        "skill": { "type": "string", "const": "02-niche-idea-scorer" },
        "web_search_confirmed": { "type": "boolean", "const": true }
      }
    },
    "niche_shortlist": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["niche_id", "niche_name", "matrix_a_score", "tier_demand", "verdict", "ebook_ideas"],
        "properties": {
          "niche_id": { "type": "string" },
          "niche_name": { "type": "string" },
          "matrix_a_score": { "type": "number" },
          "tier_demand": { "type": "string" },
          "verdict": { "type": "string" },
          "ebook_ideas": { "type": "array", "minItems": 1 }
        }
      }
    }
  }
}
